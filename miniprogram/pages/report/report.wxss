.page{padding:0 24rpx 60rpx;background:#F5F5F5;min-height:100vh}
.action-bar{background:linear-gradient(135deg,#C8102E 0%,#E8302A 100%);border-radius:20rpx;padding:32rpx 28rpx;margin:24rpx 0 20rpx;display:flex;justify-content:space-between;align-items:center}
.action-title{display:flex;align-items:center;gap:12rpx}.action-icon{font-size:40rpx}.action-text{font-size:30rpx;font-weight:600;color:#fff}.action-buttons{display:flex;gap:16rpx}
.report-btn{display:flex;align-items:center;gap:6rpx;padding:14rpx 28rpx;border-radius:36rpx;font-size:26rpx;font-weight:500;border:none;background:rgba(255,255,255,0.2);color:#fff;line-height:1}.report-btn.active{background:#fff;color:#C8102E;font-weight:600}.report-btn::after{border:none}.btn-icon{font-size:24rpx}
.report-card{background:#fff;border-radius:16rpx;margin-bottom:20rpx;overflow:hidden;box-shadow:0 2rpx 12rpx rgba(0,0,0,0.04)}
.card-header{display:flex;align-items:center;gap:16rpx;padding:24rpx 24rpx 0;margin-bottom:8rpx}.card-icon-wrapper{width:56rpx;height:56rpx;border-radius:14rpx;display:flex;align-items:center;justify-content:center;flex-shrink:0}.card-icon-text{font-size:28rpx}.card-header-title{font-size:30rpx;font-weight:700;color:#1A1A1A}
.card-body{padding:12rpx 24rpx 24rpx}.card-item{display:flex;align-items:flex-start;gap:14rpx;padding:10rpx 0;border-bottom:1rpx solid #F8F8F8}.card-item:last-child{border-bottom:none}.card-dot{width:10rpx;height:10rpx;border-radius:50%;margin-top:12rpx;flex-shrink:0}.card-item-text{font-size:26rpx;color:#444;line-height:1.7;flex:1}
.report-footer{text-align:center;padding:24rpx 0 40rpx;color:#999;font-size:22rpx}
.empty-state{background:#fff;border-radius:20rpx;padding:60rpx 40rpx 40rpx;text-align:center;margin-top:40rpx}.empty-icon{font-size:80rpx;margin-bottom:20rpx}.empty-title{display:block;font-size:32rpx;font-weight:600;color:#333;margin-bottom:8rpx}.empty-desc{font-size:26rpx;color:#999}
.empty-features{display:flex;justify-content:center;gap:32rpx;margin-top:32rpx;padding-top:32rpx;border-top:1rpx solid #F0F0F0}.feature-item{display:flex;flex-direction:column;align-items:center;gap:8rpx;font-size:24rpx;color:#666}.feature-icon{font-size:36rpx}
.loading-state{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:120rpx 0}.loading-spin{width:64rpx;height:64rpx;border:4rpx solid #F0F0F0;border-top-color:#C8102E;border-radius:50%;animation:spin .8s linear infinite}@keyframes spin{to{transform:rotate(360deg)}}.loading-text{font-size:28rpx;color:#333;margin-top:24rpx}
.history-section{background:#fff;border-radius:16rpx;padding:24rpx;margin-top:32rpx}.history-title{font-size:28rpx;font-weight:600;color:#333;margin-bottom:16rpx}.history-item{display:flex;justify-content:space-between;align-items:center;padding:16rpx 0;border-bottom:1rpx solid #F5F5F5}.history-item:last-child{border-bottom:none}.history-left{display:flex;align-items:center;gap:12rpx}.history-dot{width:12rpx;height:12rpx;border-radius:50%}.dot-daily{background:#C8102E}.dot-weekly{background:#4ECDC4}.history-type{font-size:26rpx;color:#333}.history-time{font-size:24rpx;color:#999}
