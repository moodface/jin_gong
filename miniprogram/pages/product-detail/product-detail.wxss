.page {
  padding: 0 24rpx 60rpx;
  background: #F5F5F5;
  min-height: 100vh;
}

/* 头部 */
.hero-card {
  background: linear-gradient(135deg, #C8102E 0%, #E8302A 100%);
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  margin: 20rpx 0;
  color: #fff;
  position: relative;
}
.hero-brand { font-size: 24rpx; opacity: 0.85; }
.hero-name { font-size: 34rpx; font-weight: 700; margin: 8rpx 0 16rpx; }
.hero-price-row { display: flex; align-items: baseline; gap: 16rpx; }
.hero-price-current { font-size: 52rpx; font-weight: 800; }
.hero-price-change { font-size: 22rpx; padding: 2rpx 10rpx; border-radius: 4rpx; }
.hero-price-change.up { background: rgba(82,196,26,0.3); }
.hero-price-change.down { background: rgba(255,77,79,0.3); }
.hero-meta {
  display: flex;
  gap: 20rpx;
  margin-top: 14rpx;
  font-size: 22rpx;
  opacity: 0.9;
  flex-wrap: wrap;
}
.source-badge {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  font-size: 20rpx;
  background: rgba(255,255,255,0.25);
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}
.update-time {
  display: block;
  font-size: 20rpx;
  opacity: 0.6;
  margin-top: 12rpx;
}

/* 通用区块 */
.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 8rpx;
}
.section-subtitle {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 16rpx;
}

/* 条形图 */
.bar-chart { padding: 0 4rpx; }
.bar-row { display: flex; align-items: center; gap: 10rpx; margin-bottom: 6rpx; }
.bar-label { width: 50rpx; font-size: 20rpx; color: #999; text-align: right; flex-shrink: 0; }
.bar-track { flex: 1; height: 18rpx; background: #F0F0F0; border-radius: 9rpx; overflow: hidden; }
.bar-fill { height: 100%; border-radius: 9rpx; min-width: 4rpx; }
.bar-value { width: 80rpx; font-size: 20rpx; font-weight: 500; flex-shrink: 0; }

.legend-row { display: flex; align-items: center; gap: 8rpx; margin-top: 16rpx; font-size: 20rpx; color: #999; }
.legend-dot { width: 14rpx; height: 14rpx; border-radius: 3rpx; margin-left: 16rpx; }
.legend-dot:first-child { margin-left: 0; }

/* 跨平台卡片 */
.platform-cards { display: flex; gap: 14rpx; overflow-x: auto; }
.platform-card {
  flex-shrink: 0;
  width: 220rpx;
  background: #FAFAFA;
  border-radius: 12rpx;
  padding: 18rpx;
  text-align: center;
}
.platform-name { font-size: 22rpx; color: #999; margin-bottom: 6rpx; }
.platform-price { font-size: 36rpx; font-weight: 700; color: #C8102E; }
.platform-sub { font-size: 20rpx; color: #666; margin-top: 4rpx; line-height: 1.3; }
.platform-promo { font-size: 20rpx; color: #52C41A; margin-top: 6rpx; }
.platform-arrow { font-size: 20rpx; color: #C8102E; margin-top: 10rpx; }

/* 数据来源链接 */
.platform-source-link {
  font-size: 20rpx;
  color: #2F54EB;
  margin-top: 8rpx;
  text-decoration: underline;
}
.platform-source-sim {
  font-size: 20rpx;
  color: #ccc;
  margin-top: 8rpx;
}
.comp-source {
  display: block;
  font-size: 20rpx;
  color: #2F54EB;
  margin-top: 2rpx;
  text-decoration: underline;
}
.comp-source-sim {
  display: block;
  font-size: 20rpx;
  color: #ccc;
  margin-top: 2rpx;
}

/* 竞品对比列表 */
.competitor-list { padding: 0; }
.competitor-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}
.competitor-row:last-child { border-bottom: none; }
.comp-left { flex: 1; }
.comp-brand { font-size: 26rpx; font-weight: 500; }
.comp-name { display: block; font-size: 22rpx; color: #999; margin-top: 2rpx; }
.comp-right { text-align: right; }
.comp-price { font-size: 28rpx; font-weight: 600; color: #C8102E; }
.comp-platform { display: block; font-size: 22rpx; color: #999; }

/* 评价 */
.review-card {
  background: #FAFAFA;
  border-radius: 12rpx;
  padding: 20rpx;
}
.review-tags { display: flex; gap: 10rpx; flex-wrap: wrap; margin-bottom: 14rpx; }
.review-tag {
  font-size: 22rpx;
  color: #C8102E;
  background: #FFF1F3;
  padding: 4rpx 14rpx;
  border-radius: 4rpx;
}
.review-row { display: flex; gap: 12rpx; padding: 10rpx 0; font-size: 24rpx; color: #555; }
.review-icon { font-size: 26rpx; flex-shrink: 0; }

.footer-hint {
  text-align: center;
  font-size: 20rpx;
  color: #ccc;
  padding: 20rpx 0;
}
