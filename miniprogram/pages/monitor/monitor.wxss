.page{padding-bottom:40rpx}.tabs{display:flex;background:#fff;padding:0 20rpx;border-bottom:1rpx solid #eee}.tab{flex:1;text-align:center;padding:20rpx 0;font-size:28rpx;color:#999;border-bottom:4rpx solid transparent}.tab.on{color:#C8102E;border-bottom-color:#C8102E;font-weight:600}
.source-bar{display:flex;align-items:center;gap:8rpx;padding:16rpx 24rpx;font-size:20rpx}
.source-tag{display:inline-block;padding:2rpx 10rpx;border-radius:4rpx;font-size:20rpx;font-weight:500}.source-tag.real{background:#F6FFED;color:#52C41A;border:1rpx solid #52C41A}.source-tag.market{background:#FFF7E6;color:#FA8C16;border:1rpx solid #FA8C16}.source-tag.ai{background:#F0F5FF;color:#2F54EB;border:1rpx solid #2F54EB}.source-label{color:#ccc;font-size:20rpx}
.card{background:#fff;border-radius:12rpx;margin:20rpx;padding:24rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,0.06)}.card-title{font-size:30rpx;font-weight:600;color:#333;margin-bottom:16rpx}
.scrape-btn{padding:16rpx 28rpx;background:#C8102E;color:#fff;border-radius:8rpx;font-size:26rpx;border:none}.scrape-btn::after{border:none}.scrape-methods{display:flex;flex-direction:column;gap:12rpx}.method-group{display:flex;align-items:center;justify-content:space-between;padding:8rpx 0}.method-label{font-size:24rpx;color:#666;flex:1}
.task-status.completed{color:#52C41A}.task-status.failed{color:#FF4D4F}.task-status.partial{color:#FA8C16}.task-status.running{color:#FAAD14}
.alert-danger{background:#FFF2F0;border:1rpx solid #FFCCC7;border-radius:8rpx;padding:16rpx;margin:0 20rpx 16rpx}.alert-warning{background:#FFFBE6;border:1rpx solid #FFE58F;border-radius:8rpx;padding:16rpx;margin:0 20rpx 16rpx}
