<view class="page">
  <view class="action-bar">
    <view class="action-title"><text class="action-icon">📋</text><text class="action-text">AI 智能报告</text></view>
    <view class="action-buttons">
      <button class="report-btn {{activeReport === 'daily' ? 'active' : ''}}" data-type="daily" bindtap="generateReport" loading="{{generating && activeReport === 'daily'}}"><text class="btn-icon">☀️</text><text>日报</text></button>
      <button class="report-btn {{activeReport === 'weekly' ? 'active' : ''}}" data-type="weekly" bindtap="generateReport" loading="{{generating && activeReport === 'weekly'}}"><text class="btn-icon">📅</text><text>周报</text></button>
    </view>
  </view>

  <block wx:if="{{sections.length > 0}}">
    <view class="report-card" wx:for="{{sections}}" wx:key="title" wx:for-index="idx">
      <view class="card-header" wx:if="{{item.title}}">
        <view class="card-icon-wrapper" style="background:{{idx === 0 ? '#C8102E' : idx === 1 ? '#FF6B35' : idx === 2 ? '#4ECDC4' : '#722ED1'}}"><text class="card-icon-text">{{item.icon || '📌'}}</text></view>
        <text class="card-header-title">{{item.title}}</text>
      </view>
      <view class="card-body">
        <view class="card-item" wx:for="{{item.items}}" wx:key="*this" wx:for-item="text">
          <view class="card-dot" style="background:{{idx === 0 ? '#C8102E' : idx === 1 ? '#FF6B35' : idx === 2 ? '#4ECDC4' : '#722ED1'}}"></view><text class="card-item-text">{{text}}</text>
        </view>
      </view>
    </view>
    <view class="report-footer"><text>报告由 DeepSeek AI 自动生成</text></view>
  </block>

  <view class="empty-state" wx:elif="{{!generating}}">
    <view class="empty-icon">📊</view><text class="empty-title">智能数据分析报告</text><text class="empty-desc">基于实时数据自动生成日报/周报</text>
    <view class="empty-features"><view class="feature-item"><text class="feature-icon">💡</text><text>AI 数据洞察</text></view><view class="feature-item"><text class="feature-icon">🎯</text><text>行动建议</text></view><view class="feature-item"><text class="feature-icon">⚠️</text><text>异常预警</text></view></view>
  </view>

  <view class="loading-state" wx:if="{{generating}}">
    <view class="loading-spin"></view><text class="loading-text">AI 正在分析数据...</text>
  </view>

  <view class="history-section" wx:if="{{history.length > 0}}">
    <view class="history-title">历史报告</view>
    <view class="history-item" wx:for="{{history}}" wx:key="id" data-item="{{item}}" bindtap="viewHistory">
      <view class="history-left"><view class="history-dot {{item.type === 'daily' ? 'dot-daily' : 'dot-weekly'}}"></view><text class="history-type">{{item.type === 'daily' ? '日报' : '周报'}}</text></view>
      <text class="history-time">{{item.time}}</text>
    </view>
  </view>
</view>
