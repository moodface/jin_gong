.page{padding:0 24rpx 60rpx;background:#F5F5F5;min-height:100vh}.banner{background:linear-gradient(135deg,#C8102E,#FF6B35);border-radius:16rpx;padding:24rpx 28rpx;margin:20rpx 0;display:flex;align-items:center;gap:12rpx}.banner-icon{font-size:36rpx}.banner-text{flex:1;font-size:28rpx;font-weight:500;color:#fff}.banner-action{font-size:24rpx;color:#FFD;border:1rpx solid rgba(255,255,255,0.5);padding:6rpx 16rpx;border-radius:20rpx}
.card{background:#fff;border-radius:16rpx;padding:24rpx;margin-bottom:20rpx;box-shadow:0 2rpx 8rpx rgba(0,0,0,0.03)}.card-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:14rpx}.card-title{font-size:28rpx;font-weight:600;color:#1A1A1A;margin-bottom:16rpx}.card-badge{font-size:22rpx;color:#C8102E;background:#FFF1F3;padding:4rpx 14rpx;border-radius:20rpx}
.alert{padding:16rpx;margin-bottom:12rpx;border-radius:12rpx}.alert:last-child{margin-bottom:0}.alert.warning{background:#FFFBE6}.alert.danger{background:#FFF2F0}.a-type{font-size:24rpx;font-weight:600}.a-type.price{color:#FA8C16}.a-type.sentiment{color:#CF1322}.a-msg{display:block;font-size:24rpx;color:#666;margin-top:4rpx}
.tag-grid{display:flex;flex-wrap:wrap;gap:14rpx}.sub-tag{padding:10rpx 24rpx;border-radius:30rpx;font-size:24rpx;border:1rpx solid #E0E0E0;color:#666;background:#FAFAFA}.sub-tag.on{background:#C8102E;color:#fff;border-color:#C8102E}
.toggle-row{display:flex;justify-content:space-between;align-items:center;font-size:26rpx}.toggle{width:56rpx;height:30rpx;border-radius:15rpx;background:#E0E0E0;position:relative}.toggle.on{background:#52C41A}.toggle-knob{width:26rpx;height:26rpx;border-radius:50%;background:#fff;position:absolute;top:2rpx;left:2rpx;transition:left 0.2s}.toggle.on .toggle-knob{left:28rpx}
.check-btn{background:#fff;border:2rpx solid #C8102E;color:#C8102E;border-radius:10rpx;font-size:28rpx;padding:16rpx 0}.check-btn::after{border:none}
