<view class="page">
  <view class="tabs">
    <view wx:for="{{tabs}}" wx:key="*this" class="tab {{tabIndex===index?'on':''}}" data-index="{{index}}" bindtap="switchTab">{{item}}</view>
  </view>
  <view class="source-bar">
    <text class="source-tag real">真实API</text>
    <text class="source-tag market">市场参考价</text>
    <text class="source-tag ai">AI模拟</text>
  </view>

  <view wx:if="{{tabIndex===0}}">
    <view class="card" wx:for="{{competitors}}" wx:key="id" data-id="{{item.id}}" bindtap="viewProduct">
      <view style="display:flex;justify-content:space-between;align-items:center;">
        <view style="display:flex;align-items:center;gap:12rpx;">
          <text style="font-size:28rpx;font-weight:600;">{{item.brand}}</text>
          <text class="source-tag {{item._sourceTag}}">{{item.data_source}}</text>
        </view>
        <text style="font-size:32rpx;color:#C8102E;font-weight:600;">¥{{item._priceDisplay}}</text>
      </view>
      <view style="margin-top:8rpx;display:flex;justify-content:space-between;">
        <text style="font-size:26rpx;">{{item.product_name}}</text>
        <text style="font-size:24rpx;color:#FAAD14;">⭐ {{item.rating}}</text>
      </view>
      <view style="font-size:22rpx;color:#999;margin-top:4rpx;">{{item.platform}}</view>
      <view style="margin-top:8rpx;display:flex;justify-content:space-between;font-size:22rpx;color:#999;">
        <text wx:if="{{item.promo_info}}" style="color:#C8102E;">🎫 {{item.promo_info}}</text>
        <text wx:else style="color:#ccc;">无促销</text>
        <text>{{item.review_count}}+条评价</text>
      </view>
      <view style="margin-top:4rpx;font-size:20rpx;color:#ccc;display:flex;justify-content:space-between;">
        <text style="color:#C8102E;">查看详情</text>
        <text>{{item._updateShort}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{tabIndex===1}}">
    <view class="card" wx:for="{{sentiments}}" wx:key="id">
      <view style="display:flex;align-items:center;gap:12rpx;margin-bottom:8rpx;">
        <text style="font-size:28rpx;font-weight:600;">#{{item.keyword}}</text>
        <text class="source-tag {{item._sourceTag}}">AI模拟</text>
      </view>
      <view style="font-size:22rpx;color:#999;margin-bottom:12rpx;">平台: {{item.platform}} | 提及: {{item.mention_count}}次</view>
      <view style="display:flex;align-items:center;gap:16rpx;">
        <view style="flex:1;height:20rpx;background:#eee;border-radius:10rpx;overflow:hidden;display:flex;">
          <view style="background:#52C41A;height:100%;width:{{item._posW}}%"></view>
          <view style="background:#FAAD14;height:100%;width:{{item._negW}}%"></view>
        </view>
        <text style="font-size:22rpx;color:#999;">👍{{item._posPct}}% 👎{{item._negPct}}%</text>
      </view>
    </view>
  </view>

  <view wx:if="{{tabIndex===2}}">
    <block wx:for="{{alerts}}" wx:key="time">
      <view wx:if="{{item.severity==='danger'}}" class="alert-danger">
        <text style="font-size:26rpx;font-weight:600;">🔴 {{item.type}}</text>
        <view style="font-size:24rpx;color:#999;margin-top:4rpx;">{{item.message}}</view>
      </view>
      <view wx:if="{{item.severity==='warning'}}" class="alert-warning">
        <text style="font-size:26rpx;font-weight:600;">📢 {{item.type}}</text>
        <view style="font-size:24rpx;color:#999;margin-top:4rpx;">{{item.message}}</view>
      </view>
    </block>
    <view wx:if="{{alerts.length===0}}" class="card" style="text-align:center;color:#999;"><text>暂无预警信息</text></view>
  </view>

  <view wx:if="{{tabIndex===3}}">
    <view class="card">
      <view class="card-title">手动触发爬取</view>
      <view class="scrape-methods">
        <view class="method-group">
          <text class="method-label">基础 HTTP 请求</text>
          <button class="scrape-btn" data-platform="all" bindtap="triggerScrape">微博+百度</button>
        </view>
        <view class="method-group">
          <text class="method-label">Playwright 无头浏览器</text>
          <button class="scrape-btn" data-platform="playwright" bindtap="triggerScrape">抖音</button>
        </view>
        <view class="method-group">
          <text class="method-label">Scrapy Pipeline</text>
          <button class="scrape-btn" data-platform="pipeline" bindtap="triggerScrape">Pipeline</button>
        </view>
      </view>
    </view>
    <view class="card" wx:for="{{tasks}}" wx:key="id">
      <view style="display:flex;justify-content:space-between;">
        <text style="font-weight:600;">{{item.platform}}</text>
        <text class="task-status {{item.status}}">{{item._statusText}}</text>
      </view>
      <view style="font-size:24rpx;color:#999;margin-top:8rpx;">
        <text wx:if="{{item.records_fetched>0}}">抓取: {{item.records_fetched}}条 | </text>
        <text>{{item.start_time||'未开始'}}</text>
      </view>
    </view>
  </view>
</view>
