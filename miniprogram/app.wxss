page {
  background-color: #F5F5F5;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif;
}

.card {
  background: #FFFFFF;
  border-radius: 12rpx;
  margin: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.chart-wrapper {
  width: 100%;
  height: 400rpx;
  margin: 16rpx 0;
}

.metric-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.metric-item {
  width: 48%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  color: #FFFFFF;
}

.metric-item.red {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.metric-item.green {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.metric-item.orange {
  background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
}

.metric-value {
  font-size: 48rpx;
  font-weight: 700;
}

.metric-label {
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 8rpx;
}

.alert-danger {
  background: #FFF2F0;
  border: 1rpx solid #FFCCC7;
  border-radius: 8rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.alert-warning {
  background: #FFFBE6;
  border: 1rpx solid #FFE58F;
  border-radius: 8rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
  margin-right: 8rpx;
}

.tag-positive { background: #F6FFED; color: #52C41A; }
.tag-negative { background: #FFF2F0; color: #FF4D4F; }
.tag-neutral { background: #F5F5F5; color: #999999; }
